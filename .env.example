# ============================================================
# Скопируй в .env и заполни. .env в git НЕ коммитим.
# ============================================================

# ---- Postgres (общая БД: airflow-метаданные + данные приложения) ----
POSTGRES_USER=cars
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=cars
POSTGRES_PORT=5432

# ---- Airflow ----
# UID пользователя на хосте (обычно 50000; на Linux можно поставить свой: id -u)
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Сгенерировать:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Сгенерировать:  python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=

# ---- Superset ----
# Сгенерировать:  python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# ---- Telegram ----
# Два режима сбора (выбирается автоматически в telegram_ingest):
#   - если ЗАПОЛНЕНЫ api_id/api_hash (+ есть .session) -> Telethon, полная история;
#   - если ПУСТЫ -> публичное веб-превью t.me/s/<канал>, без авторизации,
#     только публичные каналы и последние посты. Достаточно для дашборда.
# api_id / api_hash: https://my.telegram.org -> API development tools (опционально)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# каналы через запятую, без @
TELEGRAM_CHANNELS=Autofact_trade,avtosebe,CarMarketDNR,mashiny_v_spbq,mospodbor

# ---- LLM (опционально, для сложных телеграм-текстов) ----
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ---- Модель ----
MODEL_PATH=/opt/model_store/price_model.joblib

# ---- Сервис предсказания ----
# Порт наружу (внутри контейнера сервис всегда слушает 8000)
PREDICTION_PORT=8010
